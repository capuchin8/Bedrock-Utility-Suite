{
  "format_version": "1.19.40",
  "minecraft:entity": {
    "description": {
      "identifier": "bus:floatingtext",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false,
      "runtime_identifier": "minecraft:egg"
    },
    "component_groups": {
      "default.components": {
        "minecraft:conditional_bandwidth_optimization": {
          "default_values": {
            "max_optimized_distance": 80,
            "max_dropped_ticks": 7,
            "use_motion_prediction_hints": true
          }
        }
      },
      "floating.components": {
        "minecraft:scale": {
          "value": 0
        },
        "minecraft:knockback_resistance": {
          "value": 1
        },
        "minecraft:damage_sensor": {
          "triggers": [
            {
              "cause": "all",
              "deals_damage": "no"
            }
          ]
        },
        "minecraft:nameable": {
          "allow_name_tag_renaming": false,
          "always_show": true
        },
        "minecraft:physics": {
          "has_collision": false,
          "has_gravity": false
        },
        "minecraft:collision_box": {
          "height": 0,
          "width": 0
        },
        "minecraft:push_through": {
          "value": 0
        },
        "minecraft:persistent": {},
        "minecraft:conditional_bandwidth_optimization": {}
      },
      "scoreboard.components": {
        "minecraft:type_family": {
          "family": ["inanimate", "scoreboard", "summon", "magic"]
        }
      },
      "text.components": {
        "minecraft:type_family": {
          "family": ["inanimate", "text", "summon", "magic"]
        }
      }
    },
    "components": {
      "minecraft:nameable": {
        "always_show": true,
        "allow_name_tag_renaming": false
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["default.components"]
        }
      },
      "scoreboard": {
        "remove": {
          "component_groups": ["default.components"]
        },
        "add": {
          "component_groups": ["floating.components", "scoreboard.components"]
        }
      },
      "text": {
        "remove": {
          "component_groups": ["default.components"]
        },
        "add": {
          "component_groups": ["floating.components", "text.components"]
        }
      }
    }
  }
}
